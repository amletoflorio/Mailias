# ═══════════════════════════════════════════════════════════════
#  mailias — .env
#  Copy to .env and fill in all values before deploying.
#  docker compose up -d --build reads this file automatically.
# ═══════════════════════════════════════════════════════════════

# ── POCKET ID ────────────────────────────────────────────────
# Base URL of your Pocket ID instance
VITE_OIDC_AUTHORITY=https://id.yourdomain.com

# Client ID from Pocket ID dashboard → OIDC Clients → mailias
VITE_OIDC_CLIENT_ID=your_client_id

# Redirect URI after login (must match the one registered in Pocket ID)
VITE_OIDC_REDIRECT_URI=https://mailias.yourdomain.com/callback

# Redirect URI after logout
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=https://mailias.yourdomain.com

# ── CLOUDFLARE ────────────────────────────────────────────────
# Your domain
VITE_CF_DOMAIN=yourdomain.com

# Zone ID: dash.cloudflare.com → your domain → right sidebar → "Zone ID"
CF_ZONE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API Token: dash.cloudflare.com → profile → API Tokens → Create Token
# Permissions: Zone > Email Routing Rules > Edit  +  Zone > Zone > Read
CF_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── BACKEND ───────────────────────────────────────────────────
# Public URL of the backend container (exposed via Nginx Proxy Manager)
VITE_API_BASE_URL=https://api-mailias.yourdomain.com

# Public URL of the frontend — used by the backend for CORS validation
FRONTEND_URL=https://mailias.yourdomain.com
# Uncomment the line below to also allow local development requests
# FRONTEND_URL_DEV=http://localhost:5173

# Subject claim of the authorised user — found in the JWT: profile.sub
# From the Pocket ID token: "sub": "8b3c034f-a76d-44f0-9e54-..."
ALLOWED_SUB=your_sub_from_pocket_id

# ── EMAIL SENDING PROVIDER (pick one, leave the other empty) ──

# Mailgun SMTP (recommended if you already use Mailgun)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=postmaster@yourdomain.com
SMTP_PASS=your_smtp_password

# Resend (alternative)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
